# ==============================================================
# JAYESH ASSISTANT — BACKEND ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to ".env" and fill in real values.
# Never commit the real ".env" file to version control.
#
# This project runs natively (no Docker) — MongoDB, ChromaDB, and Ollama
# are expected to be running locally. See README.md for setup instructions.
# ==============================================================

# ---------------- App ----------------
APP_NAME="JAYESH Assistant"
APP_ENV=development          # development | staging | production
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# ---------------- Security ----------------
JWT_SECRET_KEY=idkqKEVgDkhiqcn4D9Xv8iKOcGMRdcXoyUaHYE1e51I
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
RATE_LIMIT_PER_MINUTE=60

# ---------------- Firebase Authentication ----------------
# Full path to your Firebase service account JSON file.
# Use an absolute path (Windows example below) to avoid issues with
# working-directory-relative paths when launching uvicorn from different places.
# Example (Windows): C:\Users\YourName\path\to\firebase-service-account.json
# Example (macOS/Linux): /home/yourname/path/to/firebase-service-account.json
FIREBASE_CREDENTIALS_PATH=C:\Users\JAYESH SADULA\OneDrive\Attachments\Desktop\jayesh-assistant\firebase-service-account.json
FIREBASE_PROJECT_ID=jayesh-assistant-93cab

# ---------------- MongoDB ----------------
# Default install of MongoDB Community Server listens on localhost:27017
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=jayesh_assistant

# ---------------- ChromaDB ----------------
# Run with: chroma run --path ./chroma_data --port 8001
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION_DOCUMENTS=jayesh_documents
CHROMA_COLLECTION_MEMORY=jayesh_memory

# ---------------- Ollama ----------------
# Default Ollama install listens on localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_DEFAULT_MODEL=qwen2.5:7b
OLLAMA_AVAILABLE_MODELS=qwen2.5:7b,llama3.1:8b,mistral:7b,gemma2:9b,deepseek-r1:7b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# ---------------- File Uploads ----------------
# Relative to the backend/ directory when running uvicorn from there.
UPLOAD_DIR=./app/uploads
MAX_UPLOAD_SIZE_MB=25
ALLOWED_UPLOAD_EXTENSIONS=.pdf,.docx,.txt,.png,.jpg,.jpeg

# ---------------- Logging ----------------
LOG_LEVEL=INFO
LOG_JSON=true
